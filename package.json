{
  "name": "svg-pixel-art",
  "packageManager": "yarn@4.13.0",
  "private": true,
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,vue,html,css}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue,html,css}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@vueuse/core": "14.2.1",
    "pinia": "3.0.4",
    "reka-ui": "2.9.2",
    "vue": "3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "24.12.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.0",
    "vitest": "3.2.4",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.5"
  }
}
